# Normalize line endings to LF on commit, checkout, and index.
# This silences the "LF will be replaced by CRLF" warnings on Windows.
* text=auto eol=lf

# Explicitly LF for source/config files
*.sh   text eol=lf
*.py   text eol=lf
*.sql  text eol=lf
*.ts   text eol=lf
*.tsx  text eol=lf
*.js   text eol=lf
*.jsx  text eol=lf
*.mjs  text eol=lf
*.cjs  text eol=lf
*.md   text eol=lf
*.json text eol=lf
*.yml  text eol=lf
*.yaml text eol=lf

# Binary — never touch line endings
*.xlsx   binary
*.parquet binary
*.png    binary
*.jpg    binary
*.jpeg   binary
*.gif    binary
*.webp   binary
*.ico    binary
