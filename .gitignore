# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/
frontend-next/.next/
frontend-next/node_modules/
frontend-next/out/

# production
/build

# data files (large, local only)
data/*.csv
data/*.xlsx

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# python
__pycache__/
*.pyc

# claude
.claude/

# local outputs and runtime artifacts
output/
venv/
*.session.json
session.json

# standalone scripts — local only, not for version control
exportar_para_excel.py
